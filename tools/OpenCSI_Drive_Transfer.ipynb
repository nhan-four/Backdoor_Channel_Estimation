      "source": [
        "# OpenCSI full reproducibility package → Google Drive\n",
        "\n",
        "Notebook này chuyển dữ liệu **server-to-server** từ GitHub Release/Figshare sang đúng thư mục Google Drive đã cấu hình. Máy cá nhân không phải tải file raw khoảng 2.03 GB.\n",
        "\n",
        "Thao tác: **Runtime → Run all**, sau đó cấp quyền Google Drive. Notebook tải từng phần, kiểm tra SHA-256, ghép raw archive, rồi upload resumable lên Drive.\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "from google.colab import auth\n",
        "auth.authenticate_user()\n",
        "\n",
        "from googleapiclient.discovery import build\n",
        "from googleapiclient.http import MediaFileUpload\n",
        "drive = build('drive', 'v3')\n",
        "\n",
        "ROOT_FOLDER_ID = '11TXh4knlWAZE1L7NHwemX421fp5dRZPK'\n",
        "RAW_FOLDER_ID = '1VQQtjsBuj_kjqbYa1Slgc7OV75Mlw7bg'\n",
        "PACKAGES_FOLDER_ID = '1lOioNSWefKK2RTmhkGFzPgeRJ_9_MYFV'\n",
        "CHECKSUMS_FOLDER_ID = '1FxxPxaUlq8ThJKO3dPsAMj040Mb_HRbn'\n",
        "PAPER_FOLDER_ID = '1DxUCcFf9r7zUx0vEcuCwpaTtJbenZ1nG'\n",
        "SOURCE_RESULTS_FOLDER_ID = '18HZV77QpQUhX9gxHlt7Ohps0Gyu5CLfp'\n",
        "\n",
        "RELEASE_TAG = 'opencsi-full-drive-transfer-v1'\n",
        "RELEASE_BASE = f'https://github.com/nhan-four/Backdoor_Channel_Estimation/releases/download/{RELEASE_TAG}'\n",
        "\n",
        "print('Google Drive authenticated.')\n",
        "print('Destination root:', f'https://drive.google.com/drive/folders/{ROOT_FOLDER_ID}')\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "import hashlib\n",
        "import json\n",
        "import pathlib\n",
        "import time\n",
        "import requests\n",
        "from urllib.parse import quote\n",
        "\n",
        "WORK = pathlib.Path('/content/opencsi_drive_transfer')\n",
        "WORK.mkdir(parents=True, exist_ok=True)\n",
        "\n",
        "SESSION = requests.Session()\n",
        "SESSION.headers.update({'User-Agent': 'OpenCSI-Repro-Transfer/1.0'})\n",
        "\n",
        "def hash_file(path, algorithm='sha256', chunk_size=8*1024*1024):\n",
        "    h = hashlib.new(algorithm)\n",
        "    with open(path, 'rb') as f:\n",
        "        for block in iter(lambda: f.read(chunk_size), b''):\n",
        "            h.update(block)\n",
        "    return h.hexdigest()\n",
        "\n",
        "def download(url, target, expected_size=None, expected_sha256=None, retries=5):\n",
        "    target = pathlib.Path(target)\n",
        "    partial = pathlib.Path(str(target) + '.part')\n",
        "    for attempt in range(1, retries + 1):\n",
        "        done = partial.stat().st_size if partial.exists() else 0\n",
        "        headers = {'Range': f'bytes={done}-'} if done else {}\n",
        "        mode = 'ab' if done else 'wb'\n",
        "        try:\n",
        "            with SESSION.get(\n",
        "                url, stream=True, timeout=(30, 300),\n",
        "                headers=headers, allow_redirects=True\n",
        "            ) as response:\n",
        "                if done and response.status_code == 200:\n",
        "                    done = 0\n",
        "                    mode = 'wb'\n",
        "                response.raise_for_status()\n",
        "                total = expected_size or (done + int(response.headers.get('content-length', 0)))\n",
        "                last_report = time.time()\n",
        "                with open(partial, mode) as output:\n",
        "                    for chunk in response.iter_content(chunk_size=8*1024*1024):\n",
        "                        if not chunk:\n",
        "                            continue\n",
        "                        output.write(chunk)\n",
        "                        done += len(chunk)\n",
        "                        if time.time() - last_report >= 5:\n",
        "                            pct = 100.0 * done / total if total else 0.0\n",
        "                            print(f'  {target.name}: {done/1e6:.1f}/{total/1e6:.1f} MB ({pct:.1f}%)')\n",
        "                            last_report = time.time()\n",
        "            break\n",
        "        except Exception as exc:\n",
        "            if attempt == retries:\n",
        "                raise\n",
        "            print(f'Retry {attempt}/{retries} for {target.name}: {exc}')\n",
        "            time.sleep(min(30, 2**attempt))\n",
        "\n",
        "    if expected_size is not None and partial.stat().st_size != expected_size:\n",
        "        raise RuntimeError(\n",
        "            f'Size mismatch for {target.name}: '\n",
        "            f'{partial.stat().st_size} != {expected_size}'\n",
        "        )\n",
        "    if expected_sha256 is not None:\n",
        "        actual = hash_file(partial, 'sha256')\n",
        "        if actual.lower() != expected_sha256.lower():\n",
        "            raise RuntimeError(\n",
        "                f'SHA-256 mismatch for {target.name}: '\n",
        "                f'{actual} != {expected_sha256}'\n",
        "            )\n",
        "    partial.replace(target)\n",
        "    return target\n",
        "\n",
        "def drive_find(parent_id, name):\n",
        "    safe = name.replace(\"'\", \\"\\\\'\\")\n",
        "    query = f\"'{parent_id}' in parents and name = '{safe}' and trashed = false\"\n",
        "    response = drive.files().list(\n",
        "        q=query,\n",
        "        fields='files(id,name,size,md5Checksum,webViewLink)',\n",
        "        pageSize=10\n",
        "    ).execute()\n",
        "    return response.get('files', [])\n",
        "\n",
        "def drive_upload(path, parent_id, mime_type='application/octet-stream'):\n",
        "    path = pathlib.Path(path)\n",
        "    existing = drive_find(parent_id, path.name)\n",
        "    for item in existing:\n",
        "        if int(item.get('size', -1)) == path.stat().st_size:\n",
        "            print('SKIP existing same-size:', path.name)\n",
        "            return item\n",
        "\n",
        "    media = MediaFileUpload(\n",
        "        str(path),\n",
        "        mimetype=mime_type,\n",
        "        resumable=True,\n",
        "        chunksize=100*1024*1024\n",
        "    )\n",
        "    request = drive.files().create(\n",
        "        body={'name': path.name, 'parents': [parent_id]},\n",
        "        media_body=media,\n",
        "        fields='id,name,size,md5Checksum,webViewLink'\n",
        "    )\n",
        "    result = None\n",
        "    while result is None:\n",
        "        status, result = request.next_chunk(num_retries=10)\n",
        "        if status:\n",
        "            print(f'  Drive {path.name}: {status.progress()*100:.1f}%')\n",
        "    print('UPLOADED:', result['name'], result.get('webViewLink', result['id']))\n",
        "    return result\n",
        "\n",
        "manifest_url = f'{RELEASE_BASE}/release_manifest.json'\n",
        "print('Reading:', manifest_url)\n",
        "manifest_response = SESSION.get(manifest_url, timeout=60)\n",
        "manifest_response.raise_for_status()\n",
        "manifest = manifest_response.json()\n",
        "\n",
        "# 1) Download four verified release parts and reconstruct the exact 2.03 GB raw archive.\n",
        "raw_parts = []\n",
        "for item in manifest['raw_parts']:\n",
        "    source_url = f\"{RELEASE_BASE}/{quote(item['name'])}\"\n",
        "    part_path = download(\n",
        "        source_url,\n",
        "        WORK / item['name'],\n",
        "        expected_size=item['size_bytes'],\n",
        "        expected_sha256=item['sha256']\n",
        "    )\n",
        "    raw_parts.append(part_path)\n",
        "\n",
        "raw_archive = WORK / manifest['raw_archive']['name']\n",
        "reconstructed = pathlib.Path(str(raw_archive) + '.reconstructing')\n",
        "with open(reconstructed, 'wb') as output:\n",
        "    for part in raw_parts:\n",
        "        with open(part, 'rb') as source:\n",
        "            for block in iter(lambda: source.read(16*1024*1024), b''):\n",
        "                output.write(block)\n",
        "\n",
        "expected_raw = manifest['raw_archive']\n",
        "if reconstructed.stat().st_size != expected_raw['size_bytes']:\n",
        "    raise RuntimeError('Reconstructed raw archive size mismatch')\n",
        "actual_raw_sha = hash_file(reconstructed, 'sha256')\n",
        "if actual_raw_sha != expected_raw['sha256']:\n",
        "    raise RuntimeError(\n",
        "        f\"Reconstructed raw SHA-256 mismatch: {actual_raw_sha} \"\n",
        "        f\"!= {expected_raw['sha256']}\"\n",
        "    )\n",
        "actual_raw_md5 = hash_file(reconstructed, 'md5')\n",
        "if actual_raw_md5 != expected_raw['md5']:\n",
        "    raise RuntimeError(\n",
        "        f\"Reconstructed raw MD5 mismatch: {actual_raw_md5} \"\n",
        "        f\"!= {expected_raw['md5']}\"\n",
        "    )\n",
        "reconstructed.replace(raw_archive)\n",
        "print('VERIFIED RAW:', raw_archive.name, raw_archive.stat().st_size)\n",
        "drive_upload(raw_archive, RAW_FOLDER_ID, 'application/zip')\n",
        "\n",
        "# 2) Download and upload exact compact data, frozen checkpoints/audit, and frozen source.\n",
        "destinations = {\n",
        "    'opencsi-compact-v8-measured.zip':\n",
        "        (SOURCE_RESULTS_FOLDER_ID, 'application/zip'),\n",
        "    'OPENCSI_FROZEN_RUNS_CHECKPOINTS.zip':\n",
        "        (SOURCE_RESULTS_FOLDER_ID, 'application/zip'),\n",
        "    'OPENCSI_REPOSITORY_SOURCE_38a6580.zip':\n",
        "        (SOURCE_RESULTS_FOLDER_ID, 'application/zip'),\n",
        "    'figshare_article_metadata.json':\n",
        "        (CHECKSUMS_FOLDER_ID, 'application/json'),\n",
        "    'README_TRANSFER.txt':\n",
        "        (CHECKSUMS_FOLDER_ID, 'text/plain'),\n",
        "}\n",
        "\n",
        "for item in manifest['package_assets']:\n",
        "    if item['name'] not in destinations:\n",
        "        raise RuntimeError(f\"Unknown release asset: {item['name']}\")\n",
        "    source_url = f\"{RELEASE_BASE}/{quote(item['name'])}\"\n",
        "    asset_path = download(\n",
        "        source_url,\n",
        "        WORK / item['name'],\n",
        "        expected_size=item['size_bytes'],\n",
        "        expected_sha256=item['sha256']\n",
        "    )\n",
        "    parent_id, mime_type = destinations[item['name']]\n",
        "    drive_upload(asset_path, parent_id, mime_type)\n",
        "\n",
        "# 3) Save release manifest and complete checksum list in Drive.\n",
        "manifest_path = WORK / 'release_manifest.json'\n",
        "manifest_path.write_text(\n",
        "    json.dumps(manifest, indent=2, sort_keys=True),\n",
        "    encoding='utf-8'\n",
        ")\n",
        "drive_upload(manifest_path, CHECKSUMS_FOLDER_ID, 'application/json')\n",
        "\n",
        "checksum_path = download(\n",
        "    f'{RELEASE_BASE}/SHA256SUMS.txt',\n",
        "    WORK / 'SHA256SUMS.txt'\n",
        ")\n",
        "drive_upload(checksum_path, CHECKSUMS_FOLDER_ID, 'text/plain')\n",
        "\n",
        "print()\n",
        "print('TRANSFER COMPLETE')\n",
        "print('Drive root:', f'https://drive.google.com/drive/folders/{ROOT_FOLDER_ID}')\n",
        "print('Raw SHA-256:', expected_raw['sha256'])\n"
      ]
    }
  ],
